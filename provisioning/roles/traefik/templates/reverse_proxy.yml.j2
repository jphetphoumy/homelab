http:
  routers:
  {% for router in traefik_configuration.routers %}
  {{ router.name }}-router:
      rule: "{{ router.rule }}"
      service: "{{ router.name }}-service"
      entryPoints:
        {{ router.entrypoints | to_nice_yaml(indent=4) }}
  {% endfor %}

  services:
  {% for service in traefik_configuration.services %}
  {{ service.name }}-service:
      loadBalancer:
        servers:
          - url: "{{ service.url }}"
  {% endfor %}

