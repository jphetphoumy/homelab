jenkins:
  securityRealm:
    local:
      allowsSignup: false
      users:
      - id: admin
        password: admin
  authorizationStrategy:
    globalMatrix:
      permissions:
        - "Overall/Administer:admin"
        - "Overall/Read:authenticated"
credentials:
  system:
    domainCredentials:
      - credentials:
          - basicSSHUserPrivateKey:
              scope: SYSTEM
              id: ssh_with_passphrase_provided
              username: root
              passphrase: admin 
              description: "SSH passphrase with private key file. Private key provided"
              privateKeySource:
                directEntry:
                  privateKey: "${readfile:/home/jenkins/.ssh/id_rsa}"
unclassified:
  location:
    url: http://{{ hostvars[inventory_hostname]['ansible_default_ipv4']['address']}}:8080
